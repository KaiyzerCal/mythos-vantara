# Supabase — get these from your project's API settings
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ElevenLabs TTS (optional — voice features degrade gracefully without this)
VITE_ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Set in Supabase Edge Function secrets (not in .env):
# ANTHROPIC_API_KEY   — used by mavis-chat, mavis-ingest, navi-* functions
# OPENAI_API_KEY      — used as fallback / embedding model
