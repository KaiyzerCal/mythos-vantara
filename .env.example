# Supabase — get these from your project's API settings
# Project URL → Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/publishable key (safe to expose in browser) → Settings → API → Project API Keys → anon public
SUPABASE_PUBLISHABLE_KEY=your-anon-public-key-here
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key-here

# Project ref ID (appears in your Supabase URL)
VITE_SUPABASE_PROJECT_ID=your-project-ref-here

# ElevenLabs TTS (optional — voice features degrade gracefully without this)
VITE_ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# ─────────────────────────────────────────────────────
# Set the following in Supabase Edge Function secrets,
# NOT in this file. Go to: Project → Edge Functions → Secrets
# ─────────────────────────────────────────────────────
# ANTHROPIC_API_KEY          — mavis-chat, mavis-ingest, council sessions
# OPENAI_API_KEY             — embeddings, image gen, fallback LLM
# GEMINI_API_KEY             — mavis-agent, primary council LLM
# GROK_API_KEY               — mavis-chat fallback
# GROQ_API_KEY               — fast/cheap fallback LLM
# TAVILY_API_KEY             — web search in mavis-chat
# ELEVENLABS_API_KEY         — server-side TTS
# TELEGRAM_BOT_TOKEN         — telegram-webhook
# TELEGRAM_CHAT_ID           — Calvin's chat ID for outbound messages
# APIFY_API_KEY              — mavis-apify actor execution
# DEEPAPI_API_KEY            — web scraping and people search
# SUPABASE_SERVICE_ROLE_KEY  — internal edge function service calls (never in .env)
